POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot
POSTGRES_DB=job_copilot
DATABASE_URL=postgresql://copilot:copilot@db:5432/job_copilot

# API key to protect the backend (leave empty to disable in local dev)
API_KEY=
